{
  "name": "cassette-slow-player",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "node node_modules/expo/bin/cli start",
    "android": "node node_modules/expo/bin/cli run:android",
    "android:start": "fuser -k 8081/tcp 2>/dev/null; adb reverse tcp:8081 tcp:8081 2>/dev/null; node node_modules/expo/bin/cli start --clear",
    "ios": "node node_modules/expo/bin/cli run:ios",
    "web": "node node_modules/expo/bin/cli start --web"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-document-picker": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
